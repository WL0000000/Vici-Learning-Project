# Copy to .env and fill in values. Never commit .env.

# Database that matches docker-compose.yml defaults
DB_NAME=vici_dashboard
DB_USERNAME=vici
DB_PASSWORD=vici

# Dev admin login Spring Security in-memory user
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

#SimplyBook.me sandbox
SIMPLYBOOK_COMPANY_LOGIN=
SIMPLYBOOK_API_KEY=
SIMPLYBOOK_ADMIN_USERNAME=
SIMPLYBOOK_ADMIN_PASSWORD=
# REST API v2 (custom client fields / memberships / invoices).
# Generate an API User Key in SimplyBook: Settings > API User Keys (preferred over the
# admin password for server use; leave blank to fall back to SIMPLYBOOK_ADMIN_PASSWORD).
SIMPLYBOOK_API_USER_KEY=
# Title of the custom client field that stores the Brevo account link (defaults to Account_ID).
SIMPLYBOOK_ACCOUNT_ID_FIELD=Account_ID

#Brevo sandbox
BREVO_API_KEY=
BREVO_API_URL=https://api.brevo.com/v3

#Notion sandbox
NOTION_TOKEN=
NOTION_TUTORS_DATA_SOURCE_ID=382afcd2-0bd4-8009-8a38-000b6a333b18
